PORT=3000

# These names double as the login "password" (case-insensitive) and the
# display name used in notification text.
BOY_NAME=Uvindu
GIRL_NAME=Tharushi

# Generate with: npm run genkeys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
CONTACT_EMAIL=you@example.com

# MongoDB Atlas (free M0 tier) — structured data. Use a different
# MONGODB_DB_NAME for local dev vs prod so testing never touches real data.
MONGODB_URI=
MONGODB_DB_NAME=thinking_of_you_dev

# Cloudinary (free tier) — uploaded music + saved drawing images
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
